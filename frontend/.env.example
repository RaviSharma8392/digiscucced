# Environment Configuration Examples
# Copy this file to .env.local, .env.staging, .env.production
# and adjust values accordingly

# ═══════════════════════════════════════════════════════════════
# Application Mode (development | staging | production)
# ═══════════════════════════════════════════════════════════════

# If MODE is not set, it will default to 'development'
# MODE=development

# ═══════════════════════════════════════════════════════════════
# API Configuration
# ═══════════════════════════════════════════════════════════════

# Development: Local backend
VITE_API_BASE_URL=http://localhost:3000/api

# Staging: Staging backend
# VITE_API_BASE_URL=https://staging-api.agency.com/api

# Production: Production backend
# VITE_API_BASE_URL=https://api.agency.com/api

# ═══════════════════════════════════════════════════════════════
# Feature Flags
# ═══════════════════════════════════════════════════════════════

# Use mock data instead of API calls (useful for development)
VITE_USE_MOCK_DATA=true

# Disable analytics in development
VITE_DISABLE_ANALYTICS=true

# Disable error tracking in development
VITE_DISABLE_ERROR_TRACKING=true

# ═══════════════════════════════════════════════════════════════
# Logging Configuration
# ═══════════════════════════════════════════════════════════════

# Log level: debug | info | warn | error
# Default: debug (development), error (production)
VITE_LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════════
# Third-party Services (Optional)
# ═══════════════════════════════════════════════════════════════

# Google Analytics
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXXXX

# Sentry Error Tracking
# VITE_SENTRY_DSN=https://xxxxxxxxxxxx@xxxx.ingest.sentry.io/xxxx

# Email Service
# VITE_EMAIL_SERVICE_API_KEY=your_api_key_here

# ═══════════════════════════════════════════════════════════════
# Build Configuration
# ═══════════════════════════════════════════════════════════════

# Source map generation in production
# VITE_SOURCEMAP=false

# Asset optimization
# VITE_BUILD_OPTIMIZE=true
